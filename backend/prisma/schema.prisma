// PostgreSQL schema — ROADMAP Phase 3, extended in Phase 6 (Zero Trust engine).
//
// Shapes are aligned with the frontend's domain types (frontend/src/types/index.ts)
// so the portal API can return them with minimal mapping.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7 no longer accepts the connection URL here — it lives in prisma.config.ts
// (for migrations) and is passed to the PrismaClient driver adapter at runtime.
datasource db {
  provider = "postgresql"
}

/// Who may read the audit trail. Deliberately coarse — this prototype needs exactly one
/// privilege boundary (ROADMAP §7 Admin/Research view), not a general RBAC system.
enum Role {
  STUDENT
  ADMIN
}

model Student {
  id           String  @id @default(cuid())
  /// The human-facing matriculation number, e.g. "SU/CS/2023/0187". Used to log in.
  studentId    String  @unique
  fullName     String
  email        String  @unique
  program      String
  level        String
  /// STUDENT for real students; ADMIN for university IT / registrar staff, who alone may read
  /// the audit trail. Defaults to STUDENT so a new account is never accidentally privileged.
  ///
  /// Staff live in this table rather than one of their own because every part of the auth stack
  /// — Session, the JWT `sub`, TOTP enrollment, the Zero Trust PEP — is keyed to Student.id. A
  /// separate Admin model would fork all of it for one boolean's worth of difference.
  role         Role    @default(STUDENT)
  /// bcrypt hash. The raw password is never stored (ROADMAP §5).
  passwordHash  String
  /// TOTP base32 secret, issued with the account. Never leaves the server after enrollment.
  totpSecret    String
  /// When the student bound this secret to an authenticator app by proving a code from it.
  /// Until then the secret is issued but unusable, and the enrollment QR may still be shown.
  /// Once set, the secret is never disclosed again — the QR is a one-time reveal.
  mfaEnrolledAt DateTime?
  /// One-time enrollment token, issued by the registrar with the account and delivered
  /// OUT OF BAND (in person / to a verified address) — deliberately NOT down the same channel
  /// as the password.
  ///
  /// It is what stops a password thief from enrolling their own authenticator before the real
  /// student ever does. Without it, whoever logs in first binds the second factor, so a stolen
  /// password alone would defeat MFA entirely on any not-yet-enrolled account.
  ///
  /// Cleared the moment it is used, so it is good for exactly one enrollment.
  enrollmentToken String? @unique

  enrollments  Enrollment[]
  fees         FeeStatement[]
  results      ResultSet[]
  sessions     Session[]
  riskEvents   RiskEvent[]
  Device       Device[]
  KnownNetwork KnownNetwork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CourseStatus {
  open
  waitlist
  closed
}

model Course {
  /// Course code is the natural key, e.g. "CSC 301".
  code       String       @id
  title      String
  credits    Int
  lecturer   String
  schedule   String
  /// Live count — incremented/decremented transactionally as students register and drop.
  seatsTaken Int
  seatsTotal Int
  /// Authored status. The API downgrades it to `closed` when seatsTaken >= seatsTotal.
  status     CourseStatus @default(open)
  department String

  enrollments Enrollment[]
}

model Enrollment {
  id           String   @id @default(cuid())
  studentId    String
  courseCode   String
  semester     String
  registeredAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseCode], references: [code], onDelete: Cascade)

  /// A student cannot register the same course twice in one semester.
  @@unique([studentId, courseCode, semester])
  @@index([studentId])
}

model FeeStatement {
  id        String @id @default(cuid())
  studentId String
  semester  String

  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  items    FeeItem[]
  payments Payment[]

  @@unique([studentId, semester])
}

enum FeeCategory {
  tuition
  accommodation
  library
  lab
  other
}

model FeeItem {
  id          String      @id @default(cuid())
  statementId String
  label       String
  /// Whole currency units (no minor units in this dataset).
  amount      Int
  category    FeeCategory

  statement FeeStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId])
}

model Payment {
  id          String   @id @default(cuid())
  statementId String
  paidAt      DateTime
  method      String
  amount      Int
  reference   String   @unique

  statement FeeStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId])
}

/// One semester's examination results (frontend: SemesterResult).
model ResultSet {
  id        String @id @default(cuid())
  studentId String
  semester  String
  /// Semester GPA. The cumulative GPA is computed across all sets, not stored.
  gpa       Float

  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  records ResultRecord[]

  @@unique([studentId, semester])
}

model ResultRecord {
  id          String @id @default(cuid())
  resultSetId String
  courseCode  String
  courseTitle String
  credits     Int
  score       Int
  grade       String
  gradePoint  Float

  resultSet ResultSet @relation(fields: [resultSetId], references: [id], onDelete: Cascade)

  @@index([resultSetId])
}

enum RevocationReason {
  LOGOUT
  TERMINATED
  EXPIRED
}

/// A login session. The JWT carries this row's id as its `jti`, so revoking the row
/// (logout, expiry, or a TERMINATE decision from the Zero Trust engine) invalidates the
/// token immediately — the Zero Trust requirement that a token alone is never sufficient.
model Session {
  id        String    @id @default(cuid())
  studentId String
  issuedAt  DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  /// Why the session ended, distinct from a plain logout — feeds the continuous-validation
  /// and session-termination-rate metrics (ROADMAP §7c).
  revokedBy RevocationReason?

  /// IP, user agent, and device fingerprint recorded at login. Compared against the
  /// Device/KnownNetwork tables (not overwritten here) so drift from the authenticated
  /// context is what the PEP's newDevice/newIpAddress signals key off.
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  /// Bumped by the PEP on every request; the continuous monitor uses this to find idle
  /// vs. active sessions.
  lastSeenAt DateTime @default(now())

  /// Set the first time this session receives a non-ALLOW decision. terminatedAt (=
  /// revokedAt) minus firstAnomalyAt is the "mean anomaly detection time" metric (§7c).
  firstAnomalyAt DateTime?

  /// True while a STEP_UP decision is outstanding and unresolved for this session.
  mfaRequired   Boolean   @default(false)
  mfaVerifiedAt DateTime?

  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  riskEvents RiskEvent[]

  @@index([studentId])
  @@index([revokedAt, lastSeenAt])
}

/// One PDP decision for one request — the off-chain record of continuous verification
/// (ROADMAP §4.3). Feeds the trust-score widget and the continuous monitor's rolling
/// re-score of active sessions.
model RiskEvent {
  id        String   @id @default(cuid())
  studentId String
  sessionId String?
  resource  String
  method    String
  riskScore Int
  /// 'ALLOW' | 'STEP_UP' | 'DENY' | 'TERMINATE' (see types/index.ts Decision) — kept as a
  /// plain string, not an enum, so Phase 8's scripted attack scenarios can label outcomes
  /// freely without a migration.
  decision  String
  /// Which signals fired, e.g. ["newIpAddress", "sensitiveResource"].
  reasons   String[]
  /// The full RiskSignals snapshot this decision was computed from.
  signals   Json
  /// True for events generated by the Phase 8 attack-simulation harness, so live-traffic
  /// metrics can exclude them.
  simulated Boolean  @default(false)
  createdAt DateTime @default(now())

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id])

  @@index([studentId])
  @@index([createdAt])
}

/// Off-chain mirror of every on-chain audit record (ROADMAP §5). Intentionally has no
/// foreign keys to Student/Session: it stands in for an independently-writable copy, so
/// the Phase 8 tampering scenario can edit it without cascading relational side effects,
/// and `verifyEventIntegrity` can catch the mismatch against the untamperable ledger copy.
model AuditMirror {
  eventId   String   @id
  studentId String
  resource  String
  decision  String
  riskScore Int
  timestamp DateTime
  hash      String
  prevHash  String
  createdAt DateTime @default(now())

  @@index([studentId])
}

/// A device this student has authenticated from before, keyed by a server-computed
/// fingerprint (see zerotrust/fingerprint.ts). Recognized across sessions, so a returning
/// device is never flagged newDevice — only the first login from it is.
model Device {
  id          String   @id @default(cuid())
  studentId   String
  fingerprint String
  userAgent   String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  Student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, fingerprint])
  @@index([studentId])
}

/// An IP address this student has authenticated from before. Same recognition model as
/// Device, for the newIpAddress signal.
model KnownNetwork {
  id          String   @id @default(cuid())
  studentId   String
  ipAddress   String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  Student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, ipAddress])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// THE LEDGER (stand-in for Hyperledger Fabric — ROADMAP Phases 4–5)
//
// These two tables are what `MockLedger` writes to. They are NOT ordinary application
// tables and nothing outside `src/ledger/` may touch them: they stand in for on-chain
// state until the real Fabric network exists, and `FabricLedger` will replace them behind
// the identical `LedgerService` interface without any caller changing.
//
// They live in PostgreSQL only because a prototype has nowhere else to put them. The
// guarantees they imitate are enforced in code (src/ledger/MockLedger.ts): append-only —
// there is no update or delete path — and hash-chained, so altering any record breaks its
// own hash and every hash after it.
//
// Why they exist at all: the previous MockLedger held the chain in a JS array, so every
// process restart silently erased the entire "immutable audit trail" and every identity
// anchor. An audit trail that evaporates on restart cannot demonstrate the property this
// project is about.
// ─────────────────────────────────────────────────────────────────────────────

/// On-chain identity anchor (IdentityContract). Never holds a raw credential — only a
/// hash and a public key (ROADMAP §5).
model LedgerIdentity {
  /// The matriculation number, e.g. "SU/CS/2023/0187" — the ledger's own key space, which
  /// is deliberately independent of PostgreSQL's internal Student.id.
  studentId      String   @id
  credentialHash String
  publicKey      String
  revoked        Boolean  @default(false)
  registeredAt   DateTime @default(now())
}

/// One append-only, hash-chained audit record (AuditContract).
model LedgerAuditRecord {
  eventId   String   @id
  /// Chain order. `prevHash` refers to the record with the preceding seq, so the chain has
  /// one unambiguous order even under concurrent writes.
  seq       Int      @unique @default(autoincrement())
  studentId String
  resource  String
  decision  String
  riskScore Int
  timestamp DateTime
  /// SHA-256 over this record's payload + prevHash — the tamper fingerprint.
  hash      String
  prevHash  String

  @@index([studentId])
  @@index([seq])
}
