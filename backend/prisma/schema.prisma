// PostgreSQL schema — ROADMAP Phase 3, extended in Phase 6 (Zero Trust engine).
//
// Shapes are aligned with the frontend's domain types (frontend/src/types/index.ts)
// so the portal API can return them with minimal mapping.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7 no longer accepts the connection URL here — it lives in prisma.config.ts
// (for migrations) and is passed to the PrismaClient driver adapter at runtime.
datasource db {
  provider = "postgresql"
}

model Student {
  id           String  @id @default(cuid())
  /// The human-facing matriculation number, e.g. "SU/CS/2023/0187". Used to log in.
  studentId    String  @unique
  fullName     String
  email        String  @unique
  program      String
  level        String
  /// bcrypt hash. The raw password is never stored (ROADMAP §5).
  passwordHash String
  /// TOTP base32 secret for step-up MFA, provisioned at seed/registration time.
  totpSecret   String

  enrollments  Enrollment[]
  fees         FeeStatement[]
  results      ResultSet[]
  sessions     Session[]
  riskEvents   RiskEvent[]
  Device       Device[]
  KnownNetwork KnownNetwork[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CourseStatus {
  open
  waitlist
  closed
}

model Course {
  /// Course code is the natural key, e.g. "CSC 301".
  code       String       @id
  title      String
  credits    Int
  lecturer   String
  schedule   String
  /// Live count — incremented/decremented transactionally as students register and drop.
  seatsTaken Int
  seatsTotal Int
  /// Authored status. The API downgrades it to `closed` when seatsTaken >= seatsTotal.
  status     CourseStatus @default(open)
  department String

  enrollments Enrollment[]
}

model Enrollment {
  id           String   @id @default(cuid())
  studentId    String
  courseCode   String
  semester     String
  registeredAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseCode], references: [code], onDelete: Cascade)

  /// A student cannot register the same course twice in one semester.
  @@unique([studentId, courseCode, semester])
  @@index([studentId])
}

model FeeStatement {
  id        String @id @default(cuid())
  studentId String
  semester  String

  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  items    FeeItem[]
  payments Payment[]

  @@unique([studentId, semester])
}

enum FeeCategory {
  tuition
  accommodation
  library
  lab
  other
}

model FeeItem {
  id          String      @id @default(cuid())
  statementId String
  label       String
  /// Whole currency units (no minor units in this dataset).
  amount      Int
  category    FeeCategory

  statement FeeStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId])
}

model Payment {
  id          String   @id @default(cuid())
  statementId String
  paidAt      DateTime
  method      String
  amount      Int
  reference   String   @unique

  statement FeeStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId])
}

/// One semester's examination results (frontend: SemesterResult).
model ResultSet {
  id        String @id @default(cuid())
  studentId String
  semester  String
  /// Semester GPA. The cumulative GPA is computed across all sets, not stored.
  gpa       Float

  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  records ResultRecord[]

  @@unique([studentId, semester])
}

model ResultRecord {
  id          String @id @default(cuid())
  resultSetId String
  courseCode  String
  courseTitle String
  credits     Int
  score       Int
  grade       String
  gradePoint  Float

  resultSet ResultSet @relation(fields: [resultSetId], references: [id], onDelete: Cascade)

  @@index([resultSetId])
}

enum RevocationReason {
  LOGOUT
  TERMINATED
  EXPIRED
}

/// A login session. The JWT carries this row's id as its `jti`, so revoking the row
/// (logout, expiry, or a TERMINATE decision from the Zero Trust engine) invalidates the
/// token immediately — the Zero Trust requirement that a token alone is never sufficient.
model Session {
  id        String    @id @default(cuid())
  studentId String
  issuedAt  DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  /// Why the session ended, distinct from a plain logout — feeds the continuous-validation
  /// and session-termination-rate metrics (ROADMAP §7c).
  revokedBy RevocationReason?

  /// IP, user agent, and device fingerprint recorded at login. Compared against the
  /// Device/KnownNetwork tables (not overwritten here) so drift from the authenticated
  /// context is what the PEP's newDevice/newIpAddress signals key off.
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  /// Bumped by the PEP on every request; the continuous monitor uses this to find idle
  /// vs. active sessions.
  lastSeenAt DateTime @default(now())

  /// Set the first time this session receives a non-ALLOW decision. terminatedAt (=
  /// revokedAt) minus firstAnomalyAt is the "mean anomaly detection time" metric (§7c).
  firstAnomalyAt DateTime?

  /// True while a STEP_UP decision is outstanding and unresolved for this session.
  mfaRequired   Boolean   @default(false)
  mfaVerifiedAt DateTime?

  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  riskEvents RiskEvent[]

  @@index([studentId])
  @@index([revokedAt, lastSeenAt])
}

/// One PDP decision for one request — the off-chain record of continuous verification
/// (ROADMAP §4.3). Feeds the trust-score widget and the continuous monitor's rolling
/// re-score of active sessions.
model RiskEvent {
  id        String   @id @default(cuid())
  studentId String
  sessionId String?
  resource  String
  method    String
  riskScore Int
  /// 'ALLOW' | 'STEP_UP' | 'DENY' | 'TERMINATE' (see types/index.ts Decision) — kept as a
  /// plain string, not an enum, so Phase 8's scripted attack scenarios can label outcomes
  /// freely without a migration.
  decision  String
  /// Which signals fired, e.g. ["newIpAddress", "sensitiveResource"].
  reasons   String[]
  /// The full RiskSignals snapshot this decision was computed from.
  signals   Json
  /// True for events generated by the Phase 8 attack-simulation harness, so live-traffic
  /// metrics can exclude them.
  simulated Boolean  @default(false)
  createdAt DateTime @default(now())

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id])

  @@index([studentId])
  @@index([createdAt])
}

/// Off-chain mirror of every on-chain audit record (ROADMAP §5). Intentionally has no
/// foreign keys to Student/Session: it stands in for an independently-writable copy, so
/// the Phase 8 tampering scenario can edit it without cascading relational side effects,
/// and `verifyEventIntegrity` can catch the mismatch against the untamperable ledger copy.
model AuditMirror {
  eventId   String   @id
  studentId String
  resource  String
  decision  String
  riskScore Int
  timestamp DateTime
  hash      String
  prevHash  String
  createdAt DateTime @default(now())

  @@index([studentId])
}

/// A device this student has authenticated from before, keyed by a server-computed
/// fingerprint (see zerotrust/fingerprint.ts). Recognized across sessions, so a returning
/// device is never flagged newDevice — only the first login from it is.
model Device {
  id          String   @id @default(cuid())
  studentId   String
  fingerprint String
  userAgent   String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  Student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, fingerprint])
  @@index([studentId])
}

/// An IP address this student has authenticated from before. Same recognition model as
/// Device, for the newIpAddress signal.
model KnownNetwork {
  id          String   @id @default(cuid())
  studentId   String
  ipAddress   String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  Student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, ipAddress])
  @@index([studentId])
}
