# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Comma-separated origins allowed by CORS (the Vite dev server by default).
CORS_ORIGIN=http://localhost:5173

# ─── Ledger (Track A vs Track B) ──────────────────────────────────────────
# mock   → MockLedger  (in-code stand-in, Windows dev — default)
# fabric → FabricLedger (Hyperledger Fabric — WSL2, later)
LEDGER=mock
