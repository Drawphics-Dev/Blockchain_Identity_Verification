# Copy to `.env` and fill in real values. Never commit `.env`, and never put a real
# password in this file — it is tracked by git.

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Comma-separated origins allowed by CORS. Vite falls back to the next free port if 5173
# is taken, so the usual fallbacks are allowed too.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ─── Ledger ───────────────────────────────────────────────────────────────
# mock   → MockLedger  (in-code stand-in — default)
# fabric → FabricLedger (Hyperledger Fabric — Phases 4–5)
LEDGER=mock

# The settings below are read ONLY when LEDGER=fabric; leave them as-is for mock.
# They point at the Fabric test-network running on the Ubuntu/WSL2 host. WSL2 forwards
# localhost, so the peer is reachable from Windows at the address below with the network up.
FABRIC_MSP_ID=Org1MSP
FABRIC_PEER_ENDPOINT=localhost:7051
# TLS SNI override: the peer's cert is issued to this name, not to "localhost", so the
# handshake fails without it even though the connection itself is fine.
FABRIC_PEER_HOST_ALIAS=peer0.org1.example.com
FABRIC_CHANNEL=mychannel
FABRIC_CHAINCODE=ziam
# Identity material copied out of the test-network's generated crypto config (gitignored —
# it is environment-specific and contains a private key). Regenerate after `network.sh down`,
# which destroys and re-creates these certs:
#   ORG=~/fabric-samples/test-network/organizations/peerOrganizations/org1.example.com
#   cp $ORG/tlsca/tlsca.org1.example.com-cert.pem                   backend/fabric-network/tlsca-cert.pem
#   cp $ORG/users/User1@org1.example.com/msp/signcerts/*.pem        backend/fabric-network/user-cert.pem
#   cp $ORG/users/User1@org1.example.com/msp/keystore/*             backend/fabric-network/user-key.pem
FABRIC_TLS_CERT_PATH=./fabric-network/tlsca-cert.pem
FABRIC_CERT_PATH=./fabric-network/user-cert.pem
FABRIC_KEY_PATH=./fabric-network/user-key.pem

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
# Prisma takes a single connection URL. Percent-encode any reserved characters in the
# password (e.g. '@' becomes %40), or the URL will not parse.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/blockchain?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────
# Signing key for session JWTs. Generate your own — do not reuse a placeholder:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-random-32-byte-hex-string"
JWT_EXPIRES_IN_HOURS=8
