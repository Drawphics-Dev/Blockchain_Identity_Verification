# Copy to `.env` and fill in real values. Never commit `.env`, and never put a real
# password in this file — it is tracked by git.

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Comma-separated origins allowed by CORS. Vite falls back to the next free port if 5173
# is taken, so the usual fallbacks are allowed too.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ─── Ledger ───────────────────────────────────────────────────────────────
# mock   → MockLedger  (in-code stand-in — default)
# fabric → FabricLedger (Hyperledger Fabric — Phases 4–5)
LEDGER=mock

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
# Prisma takes a single connection URL. Percent-encode any reserved characters in the
# password (e.g. '@' becomes %40), or the URL will not parse.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/blockchain?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────
# Signing key for session JWTs. Generate your own — do not reuse a placeholder:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-random-32-byte-hex-string"
JWT_EXPIRES_IN_HOURS=8
